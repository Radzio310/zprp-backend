# ─── Cloudflare R2 (S3-compatible) ───────────────────────────────────────────
# Endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
BACKUP_S3_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
BACKUP_S3_REGION=auto
BACKUP_S3_BUCKET=zprp-backups
BACKUP_S3_ACCESS_KEY_ID=
BACKUP_S3_SECRET_ACCESS_KEY=
BACKUP_S3_PREFIX=backups

# ─── Ścieżka katalog uploadów ─────────────────────────────────────────────────
# Na Railway z volume: /data/static  (domyślnie: $RAILWAY_VOLUME_MOUNT_PATH/static)
BACKUP_UPLOADS_DIR=/data/static

# ─── Retencja ─────────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=14

# ─── Opcjonalne: Discord lub Slack webhook przy błędzie ───────────────────────
# Discord: https://discord.com/api/webhooks/<ID>/<TOKEN>
# Slack:   https://hooks.slack.com/services/...
BACKUP_NOTIFY_WEBHOOK_URL=

# Opcjonalnie: osobny kanał dla dziennego raportu kont BAZA Beach.
# Gdy puste, raport używa BACKUP_NOTIFY_WEBHOOK_URL.
BEACH_DAILY_ACCOUNT_REPORT_WEBHOOK_URL=
